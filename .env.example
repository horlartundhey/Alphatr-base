# ── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.vwnstsw.mongodb.net/?appName=Cluster0

# ── Admin credentials ────────────────────────────────────────────────────────
# Email for the admin dashboard login
ADMIN_EMAIL=admin@alphatrack.digital

# bcrypt hash of the admin password. Generate with:
#   node -e "const b=require('bcryptjs');b.hash('yourpassword',12).then(console.log)"
ADMIN_PASSWORD_HASH=

# ── JWT ──────────────────────────────────────────────────────────────────────
# Random 64-char secret. Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# ── Brevo (email marketing) ──────────────────────────────────────────────────
BREVO_API_KEY=
BREVO_CONTACT_LIST_ID=2
BREVO_AUDIT_LIST_ID=3

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://alphatrack.digital,http://localhost:8080
